            </Text>
            
            <div className="text-center mb-6">
              <Button 
                href={resetUrl}
                className="bg-red-600 hover:bg-red-700 text-white font-bold py-3 px-6 sm:px-8 rounded-lg no-underline inline-block transition-colors"
              >
                Reset Password
              </Button>
            </div>
            
            <Text className="text-sm text-gray-500 leading-5">
