{
  "name": "starter",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging --keep-vars",
    "dev": "NODE_ENV=development react-router dev",
    "start": "NODE_ENV=development wrangler dev --live-reload --port 3000",
    "typegen": "wrangler types",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "typecheck": "tsc",
    "validate": "pnpm run lint && pnpm run format && pnpm run typecheck",
    "db:generate": "bun run --cwd packages/db drizzle-kit --config config.ts generate",
    "db:migrate": "bun db:generate && bun run --cwd packages/db drizzle-kit --config config.ts migrate",
    "db:studio": "bun run --cwd packages/db drizzle-kit --config config.ts studio"
  },
  "dependencies": {
    "@cap/auth": "workspace:*",
    "@cap/db": "workspace:*",
    "@cap/lib": "workspace:*",
    "@hono/zod-openapi": "^0.19.2",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@react-router/cloudflare": "7.4.0",
    "@remixicon/react": "^4.6.0",
    "@scalar/hono-api-reference": "^0.7.2",
    "drizzle-orm": "^0.41.0",
    "drizzle-zod": "^0.7.0",
    "hono": "^4.7.5",
    "hono-react-router-adapter": "^0.6.3",
    "isbot": "^5.1.25",
    "lucide-react": "^0.507.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "7.4.0",
    "sonner": "^2.0.3",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20250321.0",
    "@react-router/dev": "7.4.0",
    "@react-router/fs-routes": "7.4.0",
    "@react-router/remix-routes-option-adapter": "^7.5.3",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "pg": "^8.14.1",
    "postcss": "^8.5.3",
    "remix-flat-routes": "^0.8.5",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": ["packages/*"]
}
