##############################################
# Captable.inc - Production Environment
# Copy to .env.production and fill in values
##############################################

# App
NODE_ENV="production"
NEXTAUTH_URL="https://app.captable.inc"
NEXT_PUBLIC_BASE_URL="https://app.captable.inc"
NEXTAUTH_SECRET=""  # Generate with: openssl rand -base64 32

# Database
POSTGRES_USER="captable"
POSTGRES_PASSWORD=""  # Generate a strong password
POSTGRES_DB="captable"
DATABASE_URL="postgres://captable:YOUR_PASSWORD@pg:5432/captable"

# Email (SMTP) - Use Resend, AWS SES, Mailgun, etc.
EMAIL_FROM="'Captable, Inc.' <noreply@captable.inc>"
EMAIL_SERVER="smtp://username:password@smtp.provider.com:587"

# File Storage (MinIO in production, or use Cloudflare R2 / AWS S3)
UPLOAD_ENDPOINT="http://minio:9000"
NEXT_PUBLIC_UPLOAD_DOMAIN="https://files.captable.inc"  # Or your MinIO/S3 domain
UPLOAD_REGION="us-east-1"
UPLOAD_ACCESS_KEY_ID=""  # Generate a strong key
UPLOAD_SECRET_ACCESS_KEY=""  # Generate a strong secret
UPLOAD_BUCKET_PUBLIC="captable-public-bucket"
UPLOAD_BUCKET_PRIVATE="captable-private-bucket"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Sentry (optional)
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_DSN=""
