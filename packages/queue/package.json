      "types": "./index.ts"
    },
    "./base-job": {
      "import": "./src/jobs/base-job.ts",
      "types": "./src/jobs/base-job.ts"
    },
    "./types": {
      "import": "./src/types/index.ts",
      "types": "./src/types/index.ts"
    },
    "./core": {
