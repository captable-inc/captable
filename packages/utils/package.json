      "types": "./dist/lib/constants.d.ts"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc && tsc-alias"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.16",
    "typescript": "5.8.2"
  }
}
